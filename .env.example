# Discogs OAuth app credentials (https://www.discogs.com/settings/developers)
DISCOGS_CONSUMER_KEY=
DISCOGS_CONSUMER_SECRET=
DISCOGS_CALLBACK_URL=http://localhost:3000/api/oauth/callback

# iron-session encryption key (min 32 chars)
# Generate with: openssl rand -hex 32
AUTH_SECRET=

# Redis (BullMQ queue + sync progress)
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=

# Public base URL of the running app
NEXT_PUBLIC_APP_URL=http://localhost:3000
